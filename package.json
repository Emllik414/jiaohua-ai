{
  "name": "jiaohua-ai-selection-assistant",
  "productName": "饺滑-AI划词助手",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/bootstrap.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc -b && vite build",
    "start": "npm run build && electron .",
    "start:cached": "electron .",
    "lint": "oxlint",
    "test:response-format": "node response_format_tests.cjs",
    "test:ui-bugfix": "node --test ui_bugfix_tests.cjs",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "docx": "^9.7.1",
    "motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  },
  "author": "manca",
  "description": "划词即用 AI 的工具 —— 选中文本即调用 AI 翻译、解释、总结",
  "build": {
    "appId": "com.jiaohua.selection.assistant",
    "productName": "饺滑-AI划词助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/assets/**/*",
      "package.json",
      "!**/.git/**",
      "!**/logs/**",
      "!**/data/**",
      "!**/*.log",
      "!**/.env",
      "!**/.env.*",
      "!**/release/**",
      "!**/backup/**",
      "!**/backup-*/**",
      "!**/screenshots/**",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": ["**/*"]
      },
      {
        "from": "browser-extension",
        "to": "browser-extension",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "src/assets/jiao_hua_app_icon_fullset.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "饺滑-AI划词助手",
      "uninstallDisplayName": "饺滑-AI划词助手",
      "installerIcon": "src/assets/jiao_hua_app_icon_fullset.ico",
      "uninstallerIcon": "src/assets/jiao_hua_app_icon_fullset.ico",
      "installerHeaderIcon": "src/assets/jiao_hua_app_icon_fullset.ico",
      "artifactName": "饺滑-AI划词助手 Setup ${version}.exe"
    }
  }
}
