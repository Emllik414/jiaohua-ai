{
  "manifest_version": 3,
  "name": "饺滑-AI划词助手",
  "short_name": "饺滑",
  "version": "0.2.0",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "description": "配合饺滑桌面端使用的浏览器划词增强插件",
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "native-cc-segmentation.js",
        "subtitle-placement-anchor.js",
        "content.js",
        "caption-stability-v2.js"
      ],
      "run_at": "document_end",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "饺滑字幕设置",
    "default_popup": "popup.html"
  }
}
